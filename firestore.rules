rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /eventi/{eventoId} {
      // Lettura pubblica: chiunque può vedere gli eventi.
      allow read: if true;

      // Scrittura (creazione, modifica, eliminazione): solo da autenticati.
      // ATTENZIONE: per ora questo permette a QUALSIASI utente autenticato
      // di scrivere. Prima di condividere il link admin con altri,
      // collega l'autenticazione Firebase (email/password) al pannello
      // admin e qui sostituisci "if request.auth != null"
      // con un controllo su una lista di admin (es. custom claims).
      allow write: if request.auth != null;
    }
  }
}

/* ============================================
   NOTA IMPORTANTE — STATO ATTUALE
   ============================================
   Il pannello admin (public/admin/index.html) al momento NON ha
   un login. Significa che chiunque trovi l'URL /admin/ può scrivere
   sul database, perché la regola sopra controlla "request.auth != null"
   ma nessuno sta facendo login per ottenere quell'auth.

   Prima di mettere online l'app, vanno fatte DUE cose insieme:
   1. Aggiungere Firebase Authentication (email/password) alla
      pagina admin, con un account che crei tu a mano dalla
      Console Firebase.
   2. Mantenere questa regola "if request.auth != null" (che già
      blocca chi non ha fatto login).

   Fino a quel momento, NON pubblicare l'URL del pannello admin
   e tienilo solo per uso locale/test.
   ============================================ */
