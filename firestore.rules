rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // UID admin autorizzati (Firebase Console → Authentication → Users → User UID)
    // Aggiungere almeno un UID prima del deploy in produzione, oppure usare custom claim admin:true
    function adminUids() {
      return [
        // 'INCOLLA_QUI_UID_ADMIN',
      ];
    }

    function isAdmin() {
      return request.auth != null && (
        (("admin" in request.auth.token) && request.auth.token.admin == true)
        || request.auth.uid in adminUids()
      );
    }

    match /eventi/{eventoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
