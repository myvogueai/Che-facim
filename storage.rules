rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function adminUids() {
      return [
        'DQ6XqekeRPOYeEgyFcxPPpqpDTo2',
      ];
    }

    function isAdmin() {
      return request.auth != null && (
        (("admin" in request.auth.token) && request.auth.token.admin == true)
        || request.auth.uid in adminUids()
      );
    }

    function isImmagineEvento() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /eventi-covers/{eventoId}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isImmagineEvento();
      allow delete: if isAdmin();
    }
  }
}
